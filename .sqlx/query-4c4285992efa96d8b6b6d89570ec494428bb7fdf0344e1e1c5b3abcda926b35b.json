{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, queue_name, messages_total, messages_per_second, consumers_total, lag, collected_at\n            FROM queue_stats\n            WHERE queue_name = $1\n              AND collected_at >= $2\n              AND collected_at <= $3\n            ORDER BY collected_at ASC\n            ",
