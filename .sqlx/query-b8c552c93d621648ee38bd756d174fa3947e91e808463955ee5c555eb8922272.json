  "query": "\n            SELECT id, created_time, tenant_id, alias, title,\n                   image, scada, description, order_index, external_id, version\n            FROM widgets_bundle\n            WHERE ($1::text IS NULL OR LOWER(title) LIKE LOWER($1))\n            ORDER BY COALESCE(order_index, 2147483647), title\n            LIMIT $2 OFFSET $3\n            ",
