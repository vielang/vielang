{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, created_time, tenant_id, fqn, name, descriptor,\n                   deprecated, scada, image, description, tags, external_id, version\n            FROM widget_type\n            WHERE (tenant_id IS NULL OR tenant_id = $1)\n            AND ($2::text IS NULL OR LOWER(name) LIKE LOWER($2))\n            ORDER BY name\n            LIMIT $3 OFFSET $4\n            ",
