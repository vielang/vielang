  "query": "\n            SELECT id, created_time, tenant_id, device_id, request_id,\n                   expiration_time, request, response, status, additional_info\n            FROM rpc\n            WHERE tenant_id = $1 AND device_id = $2\n            ORDER BY created_time DESC\n            LIMIT $3 OFFSET $4\n            ",
