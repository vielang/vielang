{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, created_time, tenant_id, title,\n                   assigned_customers, mobile_hide, mobile_order\n            FROM dashboard\n            WHERE tenant_id = $1\n            AND ($2::text IS NULL OR LOWER(title) LIKE LOWER($2))\n            ORDER BY created_time DESC\n            LIMIT $3 OFFSET $4\n            ",
