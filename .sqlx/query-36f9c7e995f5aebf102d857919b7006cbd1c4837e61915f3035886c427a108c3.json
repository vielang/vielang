  "query": "\n            SELECT id, ts, service_id, e_type, e_entity_id, e_entity_type,\n                   e_msg_id, e_msg_type, e_data_type, e_relation_type,\n                   e_data, e_metadata, e_error\n            FROM rule_node_debug_event\n            WHERE tenant_id = $1 AND entity_id = $2\n              AND ts >= $3 AND ts < $4\n            ORDER BY ts DESC\n            LIMIT $5\n            ",
