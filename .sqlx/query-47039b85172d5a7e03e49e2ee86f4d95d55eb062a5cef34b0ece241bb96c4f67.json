{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, created_time, name, description,\n                   is_default, isolated_vl_rule_engine, profile_data, version\n            FROM tenant_profile\n            WHERE ($1::text IS NULL OR LOWER(name) LIKE LOWER($1))\n            ORDER BY created_time DESC\n            LIMIT $2 OFFSET $3\n            ",
