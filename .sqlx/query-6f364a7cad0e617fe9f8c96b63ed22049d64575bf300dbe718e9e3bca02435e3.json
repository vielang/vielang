{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT entity_id, key, ts, bool_v, str_v, long_v, dbl_v, json_v\n            FROM ts_kv\n            WHERE entity_id = $1 AND key = $2 AND ts >= $3 AND ts <= $4\n            ORDER BY ts DESC\n            LIMIT $5\n            ",
