  "query": "\n            SELECT id, ts, service_id, e_messages_processed, e_errors_occurred\n            FROM stats_event\n            WHERE tenant_id = $1 AND entity_id = $2\n              AND ts >= $3 AND ts < $4\n            ORDER BY ts DESC\n            LIMIT $5\n            ",
