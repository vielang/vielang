{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, created_time, tenant_id, customer_id,\n                   asset_profile_id, name, type as asset_type, label,\n                   external_id, additional_info, version\n            FROM asset\n            WHERE tenant_id = $1\n            AND ($2::text IS NULL OR LOWER(name) LIKE LOWER($2))\n            ORDER BY created_time DESC\n            LIMIT $3 OFFSET $4\n            ",
