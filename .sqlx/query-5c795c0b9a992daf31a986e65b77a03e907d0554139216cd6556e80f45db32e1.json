{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, created_time, tenant_id, name, target_type, target_config, version\n            FROM notification_target\n            WHERE tenant_id = $1\n            AND ($2::text IS NULL OR LOWER(name) LIKE LOWER($2))\n            ORDER BY created_time DESC\n            LIMIT $3 OFFSET $4\n            ",
