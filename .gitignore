# Build artifacts
/target/
**/target/
/target_check/
/.claude/
/.claude/worktrees/

# sqlx offline query cache — committed so CI builds without a live DB.
# Regenerate with: ./scripts/generate_sqlx_cache.sh
# .sqlx/   ← intentionally NOT ignored; keep the cache committed

# Environment variables
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Bevy / WGPU cache
bevy_asset_cache/
wgpu_trace/

# WASM build output
pkg/
dist/
web-build/

# Config overrides (giữ vielang.toml mẫu, bỏ qua file local override)
config/local.toml
config/*.local.toml

# Secrets & certs
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/

# Docker volumes
postgres-data/
redis-data/

# Benchmark output
criterion/

# Windows reserved device names (NUL, CON, PRN, etc.) — tránh lỗi commit trên Windows
nul
NUL
nul.*
NUL.*

# Test artifacts
e2e/test-results/
vielang-ui/**/test-results/

