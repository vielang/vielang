{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT k.key, lkv.str_v, lkv.long_v, lkv.dbl_v, lkv.bool_v, lkv.ts\n            FROM ts_kv_latest lkv\n            JOIN key_dictionary k ON k.key_id = lkv.key\n            WHERE lkv.entity_id = $1\n              AND k.key = ANY($2::text[])\n            ",
