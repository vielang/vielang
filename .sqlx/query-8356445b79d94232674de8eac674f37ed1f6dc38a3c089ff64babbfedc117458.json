{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT k.key, akv.str_v, akv.long_v, akv.dbl_v, akv.bool_v, akv.last_update_ts\n            FROM attribute_kv akv\n            JOIN key_dictionary k ON k.key_id = akv.attribute_key\n            WHERE akv.entity_id = $1\n              AND k.key = ANY($2::text[])\n            ",
