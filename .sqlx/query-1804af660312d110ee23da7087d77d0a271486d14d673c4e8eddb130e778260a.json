  "query": "\n            SELECT node_id, host, port, grpc_port, status, service_type,\n                   last_heartbeat, joined_at, metadata, is_leader, leader_epoch\n            FROM cluster_node\n            WHERE status = 'ACTIVE' AND last_heartbeat > $1\n            ORDER BY joined_at ASC\n            ",
